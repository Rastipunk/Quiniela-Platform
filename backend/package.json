{
  "name": "picks4all-backend",
  "version": "0.6.0",
  "description": "Picks4All backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "prisma generate && tsc",
    "start": "npx prisma migrate resolve --rolled-back 20260131120000_seed_legal_documents || true && prisma migrate deploy && node dist/server.js",
    "seed:admin": "ts-node-dev --transpile-only src/scripts/seedAdmin.ts",
    "seed:test-accounts": "ts-node-dev --transpile-only src/scripts/seedTestAccounts.ts",
    "seed:wc2026-sandbox": "ts-node-dev --transpile-only src/scripts/seedWc2026Sandbox.ts",
    "seed:legal": "ts-node-dev --transpile-only src/scripts/seedLegalDocuments.ts",
    "seed:ucl2025": "ts-node-dev --transpile-only src/scripts/seedUcl2025.ts",
    "init:smart-sync": "ts-node-dev --transpile-only src/scripts/initSmartSyncStates.ts",
    "script:fetch-ucl": "ts-node-dev --transpile-only src/scripts/fetchUclData.ts",
    "script:update-ucl-draw": "ts-node-dev --transpile-only src/scripts/updateUclR16Draw.ts",
    "script:migrate-extra-time": "ts-node-dev --transpile-only src/scripts/migrateExtraTimeConfig.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "picks4all",
    "sports",
    "predictions"
  ],
  "author": "Picks4All",
  "license": "SEE LICENSE IN LICENSE",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "prisma": "^6.19.1",
    "resend": "^6.6.0",
    "typescript": "^5.9.3",
    "zod": "^4.2.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.10",
    "@types/node-cron": "^3.0.11"
  },
  "devDependencies": {
    "ts-node-dev": "^2.0.0",
    "vitest": "^4.0.18"
  }
}
